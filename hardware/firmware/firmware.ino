/**
 * SMART GREENHOUSE - Система управления умной теплицей
 * Версия: 3.0
 * Описание: Полностью автоматизированная система управления микроклиматом
 * с поддержкой ручного режима через Bluetooth
 * 
 * Управляемые устройства:
 * - Насос (полив растений)
 * - Вентилятор (циркуляция воздуха)
 * - Освещение (досветка растений)
 * - Увлажнитель воздуха (поддержание влажности)
 * 
 * Датчики:
 * - Влажность почвы (аналоговый)
 * - Уровень воды (аналоговый)
 * - Температура (аналоговый)
 * - Освещенность (BH1750, I2C)
 * 
 * Дисплеи:
 * - LCD 16x2 (I2C) - основная информация
 * - OLED 128x64 (I2C) - заставка/доп. информация
 */

// ==================== ПОДКЛЮЧЕНИЕ БИБЛИОТЕК ====================
#include <Wire.h>                 // I2C протокол
#include <LiquidCrystal_I2C.h>    // LCD дисплей
#include <BH1750.h>               // Датчик освещенности
#include <Adafruit_GFX.h>         // Графика для OLED
#include <Adafruit_SSD1306.h>     // OLED дисплей

// ==================== КОНСТАНТЫ ПИНОВ ====================
// Датчики (аналоговые входы)
const uint8_t SOIL_MOISTURE_PIN = A0;    // Влажность почвы
const uint8_t WATER_LEVEL_PIN = A1;      // Уровень воды в баке
const uint8_t TEMP_SENSOR_PIN = A2;      // Температура

// Исполнительные устройства (цифровые выходы)
const uint8_t PUMP_SPEED_PIN = 11;        // ШИМ: скорость насоса
const uint8_t PUMP_DIR1_PIN = 12;         // Направление 1 (H-мост)
const uint8_t PUMP_DIR2_PIN = 13;         // Направление 2 (H-мост)

const uint8_t FAN_SPEED_PIN = 10;         // ШИМ: скорость вентилятора
const uint8_t FAN_DIR1_PIN = 9;           // Направление 1 (H-мост)
const uint8_t FAN_DIR2_PIN = 8;            // Направление 2 (H-мост)

const uint8_t LED_PIN = 48;                // Освещение (MOSFET)
const uint8_t HUMIDIFIER_PIN = 52;         // Увлажнитель (MOSFET)

// ==================== НАСТРОЙКИ СИСТЕМЫ ====================
// Режимы работы
bool manualMode = false;    // false = АВТО, true = РУЧНОЙ

// Bluetooth
#define BT_SERIAL Serial2

// ==================== НАСТРОЙКИ ДИСПЛЕЕВ ====================
// LCD дисплей (I2C)
LiquidCrystal_I2C lcd(0x27, 16, 2);        // Адрес 0x27, 16x2 символов

// OLED дисплей (I2C)
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);


// ==================== ДАТЧИКИ ====================
BH1750 lightMeter;              // Датчик освещенности

// Переменные для хранения показаний датчиков
struct SensorData {
  int soilMoisture = 0;      // Влажность почвы (0-1023)
  int waterLevel = 0;         // Уровень воды (0-1023)
  int temperature = 0;        // Температура (0-1023)
  uint16_t lightLevel = 0;    // Освещенность (люкс)
};

SensorData sensors;

// ==================== ПОРОГОВЫЕ ЗНАЧЕНИЯ ====================
const uint16_t WATER_LEVEL_LOW_THRESHOLD = 500;    // Мин. уровень воды
const uint16_t SOIL_DRY_THRESHOLD = 300;           // Порог сухости почвы
const uint16_t LIGHT_ON_THRESHOLD = 20;             // Порог освещенности для включения лампы

// ==================== НАСТРОЙКИ УВЛАЖНИТЕЛЯ ====================
const unsigned long HOUR_INTERVAL = 60000; //3600000;        // 1 час в миллисекундах
const unsigned long HUMIDIFIER_DURATION = 10000;    // 10 секунд работы

// Таймеры для увлажнителя
unsigned long previousHourTime = 0;      // Время последнего запуска
unsigned long pulseTimer = 0;             // Таймер для импульса
bool humidifierActive = false;            // Флаг активности увлажнителя

const float THERMISTOR_NOMINAL = 10000.0;  // Сопротивление при 25°C (10кОм)
const float TEMPERATURE_NOMINAL = 25.0;    // Температура для номинала
const float B_COEFFICIENT = 3950.0;        // B-коэффициент термистора (обычно 3950)
const float SERIES_RESISTOR = 10000.0;     // Сопротивление резистора в модуле (10кОм)

// ==================== ПРОТОТИПЫ ФУНКЦИЙ ====================
// Управление устройствами
void turnOnFan();
void stopFan();
void turnOnWaterPump();
void stopWaterPump();
void controlLight();
void controlHumidifier();

// Отображение информации
void updateLCD();
void showSplashScreen();

// Обработка команд
void processBluetoothCommands();
void automaticControl();

// Вспомогательные функции
void readAllSensors();
void stopAllActuators();

// ==================== SETUP ====================
void setup() {
  // Инициализация последовательного порта
  Serial.begin(9600);
  Serial.println(F("\n=== SMART GREENHOUSE v3.0 ==="));
  
  // Инициализация Bluetooth
  BT_SERIAL.begin(9600);
  Serial.println(F("Bluetooth initialized"));
  
  // Настройка пинов исполнительных устройств
  configureActuatorPins();
  
  // Инициализация LCD
  initLCD();
  
  // Инициализация OLED и показ заставки
  initOLED();
  
  // Инициализация датчика освещенности
  initLightSensor();
  
  // Остановка всех устройств
  stopAllActuators();
  
  Serial.println(F("=== SYSTEM READY ===\n"));
}

/**
 * Настройка пинов исполнительных устройств
 */
void configureActuatorPins() {
  // Насос (H-мост)
  pinMode(PUMP_SPEED_PIN, OUTPUT);
  pinMode(PUMP_DIR1_PIN, OUTPUT);
  pinMode(PUMP_DIR2_PIN, OUTPUT);
  
  // Вентилятор (H-мост)
  pinMode(FAN_SPEED_PIN, OUTPUT);
  pinMode(FAN_DIR1_PIN, OUTPUT);
  pinMode(FAN_DIR2_PIN, OUTPUT);
  
  // Освещение (MOSFET)
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);
  
  // Увлажнитель (MOSFET)
  pinMode(HUMIDIFIER_PIN, OUTPUT);
  digitalWrite(HUMIDIFIER_PIN, LOW);
}

/**
 * Инициализация LCD дисплея
 */
void initLCD() {
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print(F("SMART GREENHOUSE"));
  lcd.setCursor(0, 1);
  lcd.print(F("Loading..."));
  delay(1000);
  lcd.clear();
}

/**
 * Инициализация OLED дисплея и показ заставки
 */
void initOLED() {
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 not found!"));
    // Не останавливаем систему, просто продолжаем без OLED
  } else {
    display.clearDisplay();
    display.drawBitmap(0, 0, logoBitmap2, 128, 64, SSD1306_WHITE);
    display.display();
    delay(2000);
    display.clearDisplay();
  }
}

void oledDrawImage(const unsigned char* bitmap) {
 if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 not found!"));
    return;
  }
  
  display.clearDisplay();
  display.drawBitmap(0, 0, bitmap, 128, 64, SSD1306_WHITE);
  display.display();
}

/**
 * Инициализация датчика освещенности
 */
void initLightSensor() {
  if (!lightMeter.begin()) {
    Serial.println(F("BH1750 not found!"));
  } else {
    Serial.println(F("BH1750 initialized"));
  }
}

// ==================== ФУНКЦИИ УПРАВЛЕНИЯ ====================

void turnOnFan() {
  lcd.setCursor(0, 1);
  lcd.print(F("FAN ON      "));
  
  digitalWrite(FAN_DIR1_PIN, HIGH);
  digitalWrite(FAN_DIR2_PIN, LOW);
  
   // Быстрый разгон до максимума
  for (int speed = 200; speed <= 255; speed += 5) {
    analogWrite(FAN_SPEED_PIN, speed);
    delay(20);
  }
  
  Serial.println(F("FAN: ON"));
}

void stopFan() {
  lcd.setCursor(0, 1);
  lcd.print(F("FAN OFF     "));
  
  analogWrite(FAN_SPEED_PIN, 0);
  
  Serial.println(F("FAN: OFF"));
}

void turnOnWaterPump() {
  lcd.setCursor(0, 1);
  lcd.print(F("PUMP ON     "));
  
  digitalWrite(PUMP_DIR1_PIN, HIGH);
  digitalWrite(PUMP_DIR2_PIN, LOW);
  analogWrite(PUMP_SPEED_PIN, 100);
  
  Serial.println(F("PUMP: ON"));
}

void stopWaterPump() {
  lcd.setCursor(0, 1);
  lcd.print(F("PUMP OFF    "));
  
  analogWrite(PUMP_SPEED_PIN, 0);
  
  Serial.println(F("PUMP: OFF"));
}

/**
 * Управление освещением по датчику освещенности
 */
void controlLight() {
  if (sensors.lightLevel < LIGHT_ON_THRESHOLD) {
    digitalWrite(LED_PIN, HIGH);
    Serial.println(F("LIGHT: ON (dark)"));
  } else {
    digitalWrite(LED_PIN, LOW);
    Serial.println(F("LIGHT: OFF (light)"));
  }
}

/**
 * Управление увлажнителем с таймером (1 раз в час на 10 секунд)
 */
void controlHumidifier() {
  unsigned long currentTime = millis();
  
  // Первый запуск или защита от переполнения millis()
  if (previousHourTime == 0 || currentTime < previousHourTime) {
    previousHourTime = currentTime;
    return;
  }
  
  // Проверка наступления нового часа
  if (!humidifierActive && (currentTime - previousHourTime >= HOUR_INTERVAL)) {
    // Включаем увлажнитель
    digitalWrite(HUMIDIFIER_PIN, HIGH);
    humidifierActive = true;
    pulseTimer = currentTime;
    previousHourTime = currentTime;
    
    Serial.println(F("HUMIDIFIER: ON (10s)"));
    lcd.setCursor(0, 1);
    lcd.print(F("HUMID ON    "));
    turnOnFan();
  }
  
  // Выключаем через заданное время
  if (humidifierActive && (currentTime - pulseTimer >= HUMIDIFIER_DURATION)) {
    digitalWrite(HUMIDIFIER_PIN, LOW);
    humidifierActive = false;
    
    Serial.println(F("HUMIDIFIER: OFF"));
    lcd.setCursor(0, 1);
    lcd.print(F("HUMID OFF   "));
    stopFan();
  }
}

/**
 * Остановка всех устройств (аварийная)
 */
void stopAllActuators() {
  stopWaterPump();
  stopFan();
  digitalWrite(LED_PIN, LOW);
  digitalWrite(HUMIDIFIER_PIN, LOW);
  humidifierActive = false;
  Serial.println(F("All actuators stopped"));
}

// ==================== ФУНКЦИИ ОТОБРАЖЕНИЯ ====================

/**
 * Обновление показаний на LCD дисплее
 */
void updateLCD() {

  // Расчет температуры для KY-15
  float resistance = SERIES_RESISTOR * (1023.0 / sensors.temperature - 1.0);
  float temperatureC =  25.0 - (resistance - 10000.0) / 3800.0;

  // Строка 0: W:123 L:456 T:789
  lcd.setCursor(0, 0);
  lcd.print(F("W:"));
  lcd.print(sensors.soilMoisture);
  lcd.print(F(" "));
  
  lcd.setCursor(5, 0);
  lcd.print(F("L:"));
  lcd.print(sensors.waterLevel);
  lcd.print(F(" "));
  
  lcd.setCursor(10, 0);
  lcd.print(F("T:"));
  lcd.print(temperatureC);
  lcd.print(F("   "));  // Очистка остатков
}

// ==================== ФУНКЦИИ ЧТЕНИЯ ДАТЧИКОВ ====================

/**
 * Чтение всех датчиков одним вызовом
 */
void readAllSensors() {
  sensors.soilMoisture = analogRead(SOIL_MOISTURE_PIN);
  sensors.waterLevel = analogRead(WATER_LEVEL_PIN);
  sensors.temperature = analogRead(TEMP_SENSOR_PIN);
  sensors.lightLevel = lightMeter.readLightLevel();


  // Отладка в Serial (раз в 5 секунд)
  static unsigned long lastDebugTime = 0;
  unsigned long currentTime = millis();
  
  if (currentTime - lastDebugTime > 5000) {
    lastDebugTime = currentTime;
    Serial.print(F("Sensors: W="));
    Serial.print(sensors.soilMoisture);
    Serial.print(F(" L="));
    Serial.print(sensors.waterLevel);
    Serial.print(F(" T="));
    Serial.print(sensors.temperature);
    Serial.print(F(" Light="));
    Serial.println(sensors.lightLevel);
  }
}

// ==================== ОБРАБОТКА КОМАНД BLUETOOTH ====================

/**
 * Обработка команд Bluetooth
 * Команды:
 * ON1  - Ручной режим
 * OFF1 - Автоматический режим
 * ON2  - Включить насос (в ручном режиме)
 * OFF2 - Выключить насос
 * STATUS - Получить статус всех устройств
 */
void processBluetoothCommands() {
  if (!BT_SERIAL.available()) return;
  
  String command = BT_SERIAL.readString();
  command.trim();
  
  Serial.print(F("BT Command: "));
  Serial.println(command);
  
  if (command == F("ON1")) {
    manualMode = true;
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(F("MANUAL MODE"));
    stopWaterPump();
    Serial.println(F("Mode: MANUAL"));
    delay(1000);
  }
  else if (command == F("OFF1")) {
    manualMode = false;
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(F("AUTO MODE"));
    Serial.println(F("Mode: AUTO"));
    delay(1000);
  }
  else if (command == F("ON2") && manualMode) {
    turnOnWaterPump();
  }
  else if (command == F("OFF2") && manualMode) {
    stopWaterPump();
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(F("PUMP STOPPED"));
  }
  else if (command == F("STATUS")) {
    // Отправка статуса по Bluetooth
    BT_SERIAL.print(F("Mode: "));
    BT_SERIAL.println(manualMode ? F("MANUAL") : F("AUTO"));
    BT_SERIAL.print(F("Soil: ")); BT_SERIAL.println(sensors.soilMoisture);
    BT_SERIAL.print(F("Water: ")); BT_SERIAL.println(sensors.waterLevel);
    BT_SERIAL.print(F("Temp: ")); BT_SERIAL.println(sensors.temperature);
    BT_SERIAL.print(F("Light: ")); BT_SERIAL.println(sensors.lightLevel);
  }
}

// ==================== АВТОМАТИЧЕСКОЕ УПРАВЛЕНИЕ ====================

/**
 * Автоматическое управление всеми системами
 */
void automaticControl() {
  // 1. Управление поливом
  if (sensors.waterLevel < WATER_LEVEL_LOW_THRESHOLD) {
    lcd.setCursor(0, 1);
    lcd.print(F("!NO WATER!  "));
    stopWaterPump();
    Serial.println(F("ALERT: No water!"));
    oledDrawImage(logoBitmap);
  } 
  else if (sensors.soilMoisture > SOIL_DRY_THRESHOLD) {
    turnOnWaterPump();
    oledDrawImage(logoBitmap2);
  } 
  else {
    stopWaterPump();
    oledDrawImage(logoBitmap2);
  }
  
  // 2. Управление освещением
  controlLight();
  
  // 3. Управление увлажнителем
  controlHumidifier();
  
  // Здесь можно добавить управление вентилятором по температуре
  // if (sensors.temperature > TEMP_THRESHOLD) turnOnFan();
}

// ==================== ГЛАВНЫЙ ЦИКЛ ====================
void loop() {
  // 1. Чтение всех датчиков
  readAllSensors();
  
  // 2. Обновление LCD дисплея
  updateLCD();
  
  // 3. Обработка Bluetooth команд
  processBluetoothCommands();
  
  // 4. Автоматическое управление (если не ручной режим)
  if (!manualMode) {
    automaticControl();
  }
  
  // Небольшая задержка для стабильности
  delay(100);
}